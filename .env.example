# Database Configuration
POSTGRES_USER=kritis_user
POSTGRES_PASSWORD=dummy_pg_password
POSTGRES_DB=fhirbridge
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# RabbitMQ Configuration
RABBITMQ_DEFAULT_USER=mq_admin
RABBITMQ_DEFAULT_PASS=dummy_mq_password
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672/

# LLM Inference
# Internal Docker networking connects the workers to the new Ollama ROCm Container
OLLAMA_URL=http://ollama:11434

# Resource Protection & VRAM Optimization
# These values harmonize the concurrency and prefetch from RabbitMQ
# to avoid "Thundering Herd" and VRAM overflows alongside Continue.dev usage
RABBITMQ_PREFETCH_COUNT=1
LLM_MAX_CONCURRENCY=1

# Grafana Configuration
GF_SECURITY_ADMIN_PASSWORD=dummy_grafana_password
