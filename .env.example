# -----------------------------------------------------------------------
# Core Platform
# -----------------------------------------------------------------------
POSTGRES_USER=kritis_user
POSTGRES_PASSWORD=local-demo-postgres-password
POSTGRES_DB=fhirbridge
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=require

RABBITMQ_DEFAULT_USER=mq_admin
RABBITMQ_DEFAULT_PASS=local-demo-rabbitmq-password
RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672/

MINIO_ROOT_USER=fhirbridge-demo-minio
MINIO_ROOT_PASSWORD=local-demo-minio-password
MINIO_URL=https://minio.docker.localhost:9000
MINIO_EVIDENCE_BUCKET=evidence-originals
MINIO_PROCESSING_BUCKET=processing-artifacts
MINIO_PHI_VAULT_BUCKET=phi-vault
MINIO_EVIDENCE_RETENTION_DAYS=30

INTERNAL_AUTH_CONTEXT_SECRET=demo-internal-auth-context-secret-replace-in-real-setup

# -----------------------------------------------------------------------
# LLM Runtime
# -----------------------------------------------------------------------
OLLAMA_URL=http://ollama:11434
RABBITMQ_PREFETCH_COUNT=1
LLM_MAX_CONCURRENCY=1
FHIR_SERVER_URL=http://localhost:8080/fhir
FHIR_AUTH_BEARER=demo-bearer-replace-in-real-setup
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=fhirbridge-semantic-chunks
QDRANT_READ_API_KEY=demo-qdrant-read-key-replace-in-real-setup
QDRANT_WRITE_API_KEY=demo-qdrant-write-key-replace-in-real-setup

# -----------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=local-demo-grafana-password
GRAFANA_DB_NAME=grafana
GRAFANA_DB_USER=grafana_admin
GRAFANA_DB_PASSWORD=local-demo-grafana-db-password
PROMETHEUS_URL=http://localhost:9090

# -----------------------------------------------------------------------
# Keycloak / OIDC
# -----------------------------------------------------------------------
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=local-demo-keycloak-db-password
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=local-demo-keycloak-admin-password
KEYCLOAK_URL=https://keycloak.docker.localhost
KEYCLOAK_REALM=FhirBridgeAI
KEYCLOAK_CLIENT_ID=fhirbridge-api
KEYCLOAK_JWKS_URL=https://keycloak.docker.localhost/realms/FhirBridgeAI/protocol/openid-connect/certs

# Confidential client secret is injected by keycloak-bootstrap.
OAUTH2_PROXY_CLIENT_SECRET=demo-oauth2-client-secret-replace-in-real-setup
# Demo-only placeholder; replace with a generated 16/24/32 byte secret for deployment.
OAUTH2_PROXY_COOKIE_SECRET=demo-cookie-secret-replace-00000

# Security default for non-dev: strict TLS verification.
# DEV ONLY override: true (self-signed trust bootstrap scenarios).
OAUTH2_PROXY_SSL_INSECURE_SKIP_VERIFY=false

# Optional bootstrap users (temporary passwords enforced at first login).
KEYCLOAK_BOOTSTRAP_AUDITOR_USER=dr_mustermann
KEYCLOAK_BOOTSTRAP_AUDITOR_PASSWORD=local-demo-auditor-password
KEYCLOAK_BOOTSTRAP_AUDITOR_EMAIL=mustermann@fhirbridge.local
KEYCLOAK_BOOTSTRAP_VIEWER_USER=pfleger_schmidt
KEYCLOAK_BOOTSTRAP_VIEWER_PASSWORD=local-demo-viewer-password
KEYCLOAK_BOOTSTRAP_VIEWER_EMAIL=schmidt@fhirbridge.local
