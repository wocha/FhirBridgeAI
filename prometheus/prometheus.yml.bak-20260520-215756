global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "rabbitmq"
    static_configs:
      - targets: ["rabbitmq:15692"]

  - job_name: "local_workers"
    static_configs:
      - targets: ["host.docker.internal:8000"]
        labels:
          worker_type: "background_dispatcher"
